<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Admin - เพิ่มลูกค้า</title>
    <link rel="stylesheet" href="/style.css">
  </head>
  <body>
    <header>
      <h1>เพิ่มลูกค้า</h1>
      <p><a href="/">กลับไปหน้าหลัก</a></p>
    </header>
    <main>
      <form action="/admin/add-client" method="post" class="admin-form">
        <label>ชื่อลูกค้า<br><input name="name" required></label>
        <label>คำอธิบาย<br><input name="description"></label>
        <label>URL ของระบบลูกค้า<br><input name="url" required></label>
        <label>Logo (URL)<br><input name="logo"></label>
        <button type="submit" class="btn">เพิ่ม</button>
      </form>
    </main>
    <footer>
      <p>© Han</p>
    </footer>
  </body>
</html>
